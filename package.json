{
  "name": "@ozzylabs/knowledge-mcp-server",
  "version": "0.1.0",
  "description": "MCP server providing verified, up-to-date knowledge base for AI agents",
  "type": "module",
  "bin": {
    "knowledge-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-index": "node scripts/generate-index.mjs",
    "validate-staleness-sources": "node scripts/staleness/validate.mjs",
    "staleness:status": "scripts/staleness/status.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "ajv": "8.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "2.8.4"
  },
  "pnpm": {
    "overrides": {
      "ip-address": "^10.1.1"
    }
  },
  "license": "MIT"
}
