{
  "name": "@ozzylabs/mcp-server-knowledge",
  "version": "0.1.1",
  "description": "MCP server providing verified, up-to-date knowledge base for AI agents",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "knowledge",
    "!knowledge/_private",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "mcp-server-knowledge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-index": "node scripts/generate-index.mjs",
    "validate-staleness-sources": "node scripts/staleness/validate.mjs",
    "staleness:status": "scripts/staleness/status.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "ajv": "8.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "2.8.4"
  },
  "pnpm": {
    "overrides": {
      "ip-address": "^10.1.1",
      "fast-uri": "^3.1.1",
      "hono": "^4.12.16"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozzy-labs/mcp-server-knowledge.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "knowledge-base",
    "ai-agents"
  ],
  "author": "ozzy-labs"
}
